# ──────────────────────────────────────────────────
# SENATE — Environment Variables
# ──────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# For local development, only NETWORK=localhost is needed.
# ──────────────────────────────────────────────────

# ─── Network ──────────────────────────────────────
# Options: localhost | sepolia
# localhost = local Hardhat node (no keys needed, free gas)
# sepolia   = Sepolia testnet (needs RPC_URL + PRIVATE_KEY + Sepolia ETH)
NETWORK=localhost
CHAIN_ID=31337
RPC_URL=http://127.0.0.1:8545
BLOCK_EXPLORER_URL=

# For Sepolia, use:
# NETWORK=sepolia
# CHAIN_ID=11155111
# RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# BLOCK_EXPLORER_URL=https://sepolia.etherscan.io

# ─── Wallet ───────────────────────────────────────
# For localhost: not needed (Hardhat provides 20 funded accounts)
# For Sepolia:  export from MetaMask -> Account Details -> Export Private Key
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ─── Contracts (filled after deploying) ───────────
SENATE_REPORT_CONTRACT=
SENATE_GOVERNOR_CONTRACT=
SENATE_RISK_ORACLE_CONTRACT=
CRE_FORWARDER_ADDRESS=0x15fC6ae953E024d975e77382eEeC56A9101f9F88

# ─── LLM / AI (optional — falls back to mock debate) ──
# Using Google Gemini (cheapest: gemini-2.0-flash-lite)
# Get a free API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# ─── Tenderly (optional — falls back to mock simulation) ─
TENDERLY_ACCOUNT=
TENDERLY_PROJECT=senate
TENDERLY_ACCESS_KEY=
TENDERLY_VTN_RPC=
TENDERLY_VTN_EXPLORER_URL=
TENDERLY_VTN_CHAIN_ID=1

# ─── CRE (only needed for DON deployment) ────────
CRE_API_KEY=
CRE_DON_ID=
CRE_WORKFLOW_ENDPOINT=

# ─── Etherscan (optional — for contract verification) ─
ETHERSCAN_API_KEY=

# ─── MongoDB (optional — demo mode is in-memory) ──
MONGODB_URI=

# ─── App ──────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEMO_MODE=true
DEBATE_WEBHOOK_SECRET=

# ─── Frontend public vars (filled after deploying) ─
NEXT_PUBLIC_SENATE_REPORT_SEPOLIA=
NEXT_PUBLIC_SENATE_GOVERNOR_SEPOLIA=
NEXT_PUBLIC_SENATE_RISK_ORACLE_SEPOLIA=
NEXT_PUBLIC_SENATE_REPORT_VTN=
NEXT_PUBLIC_SENATE_GOVERNOR_VTN=
NEXT_PUBLIC_SENATE_RISK_ORACLE_VTN=
NEXT_PUBLIC_TENDERLY_EXPLORER=
NEXT_PUBLIC_TENDERLY_VTN_RPC=
NEXT_PUBLIC_GITHUB_REPO=
NEXT_PUBLIC_DEMO_URL=
NEXT_PUBLIC_VIDEO_URL=
